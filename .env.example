# server/.env
PORT=3001
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
CLERK_SECRET_KEY=sk_live_...
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
# production | sandbox — use production if you only have a live Paddle account
PADDLE_ENVIRONMENT=production
CLIENT_URL=http://localhost:5173
# Local: postgresql://YOUR_USER@localhost:5432/polished
# Supabase: Project Settings → Database → Connection string → URI (use "Session" mode for this Express app)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# client/.env
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
VITE_API_BASE_URL=http://localhost:3001
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_PRICE_ID=
